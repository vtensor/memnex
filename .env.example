# =============================================================================
# Memnex environment configuration
# =============================================================================
#
# IMPORTANT — there are two distinct categories of env vars below.
# Mixing them up is the most common deployment mistake.
#
#   SERVER-SIDE: set by whoever runs the Memnex server (us in hosted SaaS,
#                you in self-host). Contains infrastructure secrets.
#                Never share with tenants. Never put in an MCP client config.
#
#   CLIENT-SIDE: set by the tenant in their MCP client config (Claude Desktop,
#                Cursor, etc.). Just an API key + an optional channel label.
#
# Copy this file to `.env` and fill in real values for whichever side you
# are operating on.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER-SIDE — only the operator sets these
# -----------------------------------------------------------------------------

# Storage backends. Leave unset to use in-memory fallback (good for dev
# and tests; do NOT use in production).
MEMNEX_POSTGRES_URL=postgresql://memnex:memnex@localhost:5432/memnex
MEMNEX_REDIS_URL=redis://localhost:6379/0
MEMNEX_QDRANT_URL=http://localhost:6333

# Embeddings. Default provider is Google Generative AI via LangChain.
GOOGLE_API_KEY=

# Audit ledger HMAC key. 32+ bytes recommended. Used to sign write
# receipts so tenants can prove tamper-evidence to a regulator.
MEMNEX_AUDIT_KEY=

# JWT signing key for the SaaS dashboard (register/login flow).
# Required if you mount the SaaS routes (memnex serve mcp --transport
# streamable-http or memnex serve rest). 32+ bytes recommended.
MEMNEX_JWT_SIGNING_KEY=

# Local dev convenience. When set to "1", `memnex serve mcp` registers a
# throwaway dev tenant on boot and prints the API key to stderr — useful
# for testing the MCP server against Claude Desktop without going through
# the full SaaS register/login flow. NEVER set in production.
MEMNEX_DEV_KEY=

# -----------------------------------------------------------------------------
# Legacy / opt-in (almost no one needs to set these)
# -----------------------------------------------------------------------------
# Memnex's structured-fact path (the recommended one used by all tools and
# prompts) never invokes a generative LLM. These two variables only have an
# effect if you flip MEMNEX_LLM_PROVIDER away from "none" AND your agents
# send unstructured `raw_text` to memory_write. Leave both unset unless you
# specifically know you need raw_text extraction.
# Values: openai | anthropic | google | ollama | none
MEMNEX_LLM_PROVIDER=none
MEMNEX_LLM_API_KEY=


# -----------------------------------------------------------------------------
# CLIENT-SIDE — set by the tenant in their MCP client config
# -----------------------------------------------------------------------------

# The tenant's API key, issued by the Memnex dashboard. Format:
# `mx_live_kXXXXXXXX_<44 base64 chars>`.
MEMNEX_SECRET_KEY=

# Which channel this agent represents. One of: voice | whatsapp | web | sms | app.
# Used to format read responses (voice gets short bullets; web gets markdown).
MEMNEX_CHANNEL=app
